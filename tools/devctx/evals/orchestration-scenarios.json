{
  "version": 1,
  "thresholds": {
    "minScenarioPassRatePct": 100,
    "minNetSavedTokens": 150,
    "minContinuityAlignmentRatePct": 20,
    "minBlockedRemediationCoveragePct": 100,
    "minRefreshTopFileSignalRatePct": 80,
    "minCheckpointPersistenceRatePct": 50,
    "minRunnerWorkflowCoveragePct": 100,
    "minRunnerPreflightCoveragePct": 50,
    "minRunnerDoctorCoveragePct": 100
  },
  "scenarios": [
    {
      "id": "aligned-resume",
      "description": "Reuses aligned persisted context and keeps the flow on compressed reads",
      "seedSession": {
        "sessionId": "bench-aligned",
        "update": {
          "goal": "Finish the auth metrics repo safety tests",
          "status": "in_progress",
          "currentFocus": "auth metrics repo safety",
          "nextStep": "Inspect loginHandler and keep runtime enforcement in place"
        }
      },
      "start": {
        "sessionId": "bench-aligned",
        "prompt": "Finish the auth metrics repo safety tests and keep runtime enforcement in place",
        "ensureSession": false
      },
      "actions": [
        {
          "type": "smart_read",
          "filePath": "src/auth.js",
          "mode": "outline"
        }
      ],
      "expect": {
        "continuityState": "aligned",
        "shouldReuseContext": true,
        "mutationBlocked": false,
        "recommendedPathMode": "guided_context"
      }
    },
    {
      "id": "context-refresh",
      "description": "Creates a meaningful start that refreshes context and surfaces top files",
      "start": {
        "prompt": "Fix the token error in loginHandler and continue the auth debugging flow",
        "ensureSession": true
      },
      "actions": [
        {
          "type": "smart_context",
          "task": "Fix the token error in loginHandler and continue the auth debugging flow"
        }
      ],
      "expect": {
        "refreshedContext": true,
        "refreshedTopFilesMin": 1,
        "recommendedPathMode": "guided_refresh"
      }
    },
    {
      "id": "blocked-remediation",
      "description": "Stages state.sqlite and verifies blocked-state remediation is surfaced",
      "seedSession": {
        "sessionId": "bench-blocked",
        "update": {
          "goal": "Debug blocked workflow tracking",
          "status": "in_progress",
          "currentFocus": "Repo safety enforcement"
        }
      },
      "stageStateDb": true,
      "start": {
        "sessionId": "bench-blocked",
        "prompt": "Continue the blocked debugging workflow safely",
        "ensureSession": false
      },
      "actions": [
        {
          "type": "smart_search",
          "query": "loginHandler",
          "cwd": ".",
          "intent": "debug"
        }
      ],
      "expect": {
        "mutationBlocked": true,
        "blockedByIncludes": ["tracked", "staged"],
        "recommendedPathMode": "blocked_guided"
      }
    },
    {
      "id": "skipped-checkpoint",
      "description": "Keeps file_change checkpoints weak so they are skipped until a real milestone exists",
      "start": {
        "prompt": "Inspect auth implementation details and keep working until a real milestone exists",
        "ensureSession": true
      },
      "actions": [
        {
          "type": "smart_read",
          "filePath": "src/auth.js",
          "mode": "outline"
        },
        {
          "type": "smart_turn_end",
          "event": "file_change",
          "update": {
            "touchedFiles": ["src/auth.js"]
          }
        }
      ],
      "expect": {
        "checkpointSkipped": true,
        "endRecommendedPathMode": "continue_until_milestone"
      }
    },
    {
      "id": "persisted-checkpoint",
      "description": "Persists a milestone checkpoint after real progress",
      "start": {
        "prompt": "Fix the login error in the auth handler and checkpoint the first milestone safely",
        "ensureSession": true
      },
      "actions": [
        {
          "type": "smart_search",
          "query": "loginHandler",
          "cwd": ".",
          "intent": "debug"
        },
        {
          "type": "smart_read",
          "filePath": "src/auth.js",
          "mode": "outline"
        },
        {
          "type": "smart_turn_end",
          "event": "milestone",
          "update": {
            "completed": ["Fixed the login error"],
            "nextStep": "Run the regression tests"
          }
        }
      ],
      "expect": {
        "checkpointPersisted": true,
        "endRecommendedPathMode": "checkpointed"
      }
    },
    {
      "id": "runner-review-guidance",
      "description": "Runs the review workflow through task_runner and captures preflight guidance",
      "runner": {
        "commandName": "review",
        "client": "cursor",
        "prompt": "Review the auth and wrapper changes, then surface concrete risks first",
        "dryRun": true
      },
      "expect": {
        "runnerSuccess": true,
        "runnerBlocked": false,
        "runnerUsedWrapper": true,
        "runnerWorkflowIntent": "explore",
        "runnerPolicyMode": "review_guided",
        "runnerPreflightTool": "smart_context",
        "runnerPreflightTopFilesMin": 1
      }
    },
    {
      "id": "runner-blocked-doctor",
      "description": "Routes blocked task_runner workflows through doctor before execution",
      "seedSession": {
        "sessionId": "bench-runner-blocked",
        "update": {
          "goal": "Resume the blocked review workflow",
          "status": "in_progress",
          "currentFocus": "Repo safety blocked state"
        }
      },
      "stageStateDb": true,
      "runner": {
        "commandName": "debug",
        "client": "cursor",
        "prompt": "Debug the blocked workflow path safely",
        "dryRun": true
      },
      "expect": {
        "mutationBlocked": true,
        "runnerSuccess": false,
        "runnerBlocked": true,
        "runnerDoctorIssued": true,
        "runnerPolicyMode": "debug_guided"
      }
    },
    {
      "id": "runner-checkpoint",
      "description": "Persists a milestone through the task_runner checkpoint command",
      "seedSession": {
        "sessionId": "bench-runner-checkpoint",
        "update": {
          "goal": "Checkpoint the task runner benchmark flow",
          "status": "in_progress",
          "currentFocus": "checkpoint command"
        }
      },
      "runner": {
        "commandName": "checkpoint",
        "client": "cursor",
        "sessionId": "bench-runner-checkpoint",
        "event": "milestone",
        "update": {
          "completed": ["Checkpointed the runner flow"],
          "nextStep": "Inspect the persisted benchmark session"
        }
      },
      "expect": {
        "checkpointPersisted": true
      }
    }
  ]
}

{
  "name": "devctx-mcp",
  "version": "0.6.0",
  "description": "Local MCP server that gives AI agents compact file summaries, ranked code search, and safe diagnostic shell access.",
  "author": "Francisco Caballero Portero <fcp1978@hotmail.com>",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arrayo/devctx-mcp-mvp.git"
  },
  "homepage": "https://github.com/Arrayo/devctx-mcp-mvp#readme",
  "bugs": {
    "url": "https://github.com/Arrayo/devctx-mcp-mvp/issues"
  },
  "bin": {
    "devctx-server": "scripts/devctx-server.js",
    "devctx-init": "scripts/init-clients.js"
  },
  "exports": {
    ".": "./src/server.js",
    "./server": "./src/server.js"
  },
  "files": [
    "src/",
    "scripts/devctx-server.js",
    "scripts/init-clients.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-tools",
    "code-search",
    "ripgrep",
    "devtools"
  ],
  "scripts": {
    "start": "node ./scripts/devctx-server.js",
    "smoke": "node ./scripts/smoke-test.js",
    "smoke:json": "node ./scripts/smoke-test.js --json",
    "init:clients": "node ./scripts/init-clients.js",
    "smoke:formats": "node ./scripts/format-smoke.js",
    "test": "node --test ./tests/*.test.js",
    "eval": "node ./evals/harness.js",
    "eval:report": "node ./evals/report.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@vscode/ripgrep": "^1.17.1",
    "js-tiktoken": "^1.0.21",
    "typescript": "^6.0.2",
    "zod": "^4.1.5"
  }
}
